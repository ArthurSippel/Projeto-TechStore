<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Editar</title>
</head>
<body>

    <h1>EDITAR CADASTROS</h1>

    <% if (tipo === 'cliente') { %>

        <h2>Editar Cliente</h2>

        <form action="/cliente/atualizar" method="POST">

            <input type="hidden" name="ID_Cliente" value="<%= registro.ID_Cliente %>">

            <label>Nome:</label><br>
            <input type="text" name="Nome_Cliente" value="<%= registro.Nome_Cliente %>" required><br><br>

            <label>Email:</label><br>
            <input type="email" name="Email" value="<%= registro.Email %>" required><br><br>

            <label>Telefone:</label><br>
            <input type="text" name="Telefone" value="<%= registro.Telefone %>" required><br><br>

            <button type="submit">Salvar</button>
        </form>

    <% } %>


    <% if (tipo === 'produto') { %>

        <h2>Editar Produto</h2>

        <form action="/produto/atualizar" method="POST">

            <input type="hidden" name="ID_Produtos" value="<%= registro.ID_Produtos %>">

            <label>Nome:</label><br>
            <input type="text" name="Nome_Produtos" value="<%= registro.Nome_Produtos %>" required><br><br>

            <label>Preço:</label><br>
            <input type="number" name="Preco" step="0.01" value="<%= registro.Preco %>" required><br><br>

            <label>Cliente:</label><br>
            <select name="ID_Cliente" required>
                <% clientes.forEach(cliente => { %>
                    <option value="<%= cliente.ID_Cliente %>" 
                        <%= cliente.ID_Cliente == registro.ID_Cliente ? 'selected' : '' %>>
                        <%= cliente.Nome_Cliente %>
                    </option>
                <% }) %>
            </select><br><br>

            <label>Categoria:</label><br>
            <select name="ID_Categorias" required>
                <% categorias.forEach(categoria => { %>
                    <option value="<%= categoria.ID_Categorias %>" 
                        <%= categoria.ID_Categorias == registro.ID_Categorias ? 'selected' : '' %>>
                        <%= categoria.Nome_Categorias %>
                    </option>
                <% }) %>
            </select><br><br>

            <button type="submit">Salvar</button>
        </form>

    <% } %>

    <br>
    <a href="/"><button>Voltar</button></a>

</body>
</html>