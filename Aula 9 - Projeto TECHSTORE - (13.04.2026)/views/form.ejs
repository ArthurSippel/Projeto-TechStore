<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Cadastro</title>
</head>
<body>

    <h1>CADASTROS</h1>

    <% if (tipo === 'cliente') { %>

        <h2>Cadastrar Cliente</h2>
        

        <form action="/cliente/adicionar" method="POST">

            <label>Nome:</label><br>
            <input type="text" name="nome_clientes" required><br><br>

            <label>Email:</label><br>
            <input type="email" name="email_clientes" required><br><br>

            <label>Telefone:</label><br>
            <input type="text" name="telefone_clientes" required><br><br>

            <button type="submit">Salvar</button>
        </form>

    <% } %>


    <% if (tipo === 'produto') { %>

        <h2>Cadastrar Produto</h2>

        <form action="/produto/adicionar" method="POST">

            <label>Nome:</label><br>
            <input type="text" name="nome_produtos" required><br><br>

            <label>Preço:</label><br>
            <input type="number" name="preco_produtos" step="0.01" required><br><br>

            <label>Categoria:</label><br>
            <select name="id_categorias" required>
                <% categorias.forEach(categorias => { %>
                    <option value="<%= categorias.id_categorias %>">
                        <%= categorias.nome_categorias %>
                    </option>
                <% }) %>
            </select><br><br>

            <button type="submit">Salvar</button>
        </form>

    <% } %>




    <% if (tipo === 'categoria') { %>

        <h2>Cadastrar Categoria</h2>
        

        <form action="/categoria/adicionar" method="POST">

            <label>Nome:</label><br>
            <input type="text" name="nome_categorias" required><br><br>

            <button type="submit">Salvar</button>
        </form>

    <% } %>
    
    <br>
    <a href="/"><button>Voltar</button></a>

</body>
</html>